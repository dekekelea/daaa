local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- UI Stylée
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = LocalPlayer.PlayerGui

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 350, 0, 500)
MainFrame.Position = UDim2.new(0, 20, 0, 20)
MainFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 28)
MainFrame.Parent = ScreenGui
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 14)

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 50)
Title.BackgroundColor3 = Color3.fromRGB(0, 100, 220)
Title.Text = "Blox Tracker by Exot"
Title.TextColor3 = Color3.new(1,1,1)
Title.TextScaled = true
Title.Font = Enum.Font.GothamBold
Title.Parent = MainFrame
Instance.new("UICorner", Title).CornerRadius = UDim.new(0, 14)

local Scrolling = Instance.new("ScrollingFrame")
Scrolling.Size = UDim2.new(1, -20, 1, -70)
Scrolling.Position = UDim2.new(0, 10, 0, 60)
Scrolling.BackgroundTransparency = 1
Scrolling.ScrollBarThickness = 6
Scrolling.Parent = MainFrame

local List = Instance.new("UIListLayout")
List.Padding = UDim.new(0, 12)
List.Parent = Scrolling

local function GetIsland(pos)
    if not pos then return "Inconnue" end
    local y = pos.Y
    if y > 14500 then return "Hydra Island"
    elseif y > 9500 then return "Tiki Outpost"
    elseif y > 6200 then return "Sea 3 - Zone Principale"
    elseif y > 2800 then return "Port Town"
    elseif y > 1500 then return "Cocoa Island"
    elseif y > 600 then return "Kingdom of Rose"
    else return "First Sea" end
end

local function CreateRainbowLine()
    local line = Drawing.new("Line")
    line.Thickness = 2.5
    line.Transparency = 1
    return line
end

local function CreateEntry(player)
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(1, 0, 0, 125)
    Frame.BackgroundColor3 = Color3.fromRGB(28, 28, 45)
    Frame.Parent = Scrolling
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 10)

    local Name = Instance.new("TextLabel")
    Name.Size = UDim2.new(1, 0, 0, 28)
    Name.BackgroundTransparency = 1
    Name.Text = player.Name
    Name.TextColor3 = Color3.fromRGB(255, 255, 255)
    Name.TextScaled = true
    Name.Font = Enum.Font.GothamBold
    Name.Parent = Frame

    local ls = player:FindFirstChild("leaderstats")
    local beli = ls and ls:FindFirstChild("Beli") and ls.Beli.Value or 0
    local level = ls and ls:FindFirstChild("Level") and ls.Level.Value or 0
    local bounty = ls and ls:FindFirstChild("Bounty") and ls.Bounty.Value or 0

    local Stats = Instance.new("TextLabel")
    Stats.Size = UDim2.new(1, 0, 0, 50)
    Stats.Position = UDim2.new(0, 0, 0, 28)
    Stats.BackgroundTransparency = 1
    Stats.Text = "Lv." .. level .. "   |   Beli: " .. beli .. "   |   Bounty: " .. bounty
    Stats.TextColor3 = Color3.fromRGB(200, 200, 255)
    Stats.TextScaled = true
    Stats.Parent = Frame

    local IslandLabel = Instance.new("TextLabel")
    IslandLabel.Size = UDim2.new(1, 0, 0, 22)
    IslandLabel.Position = UDim2.new(0, 0, 0, 78)
    IslandLabel.BackgroundTransparency = 1
    IslandLabel.Text = "Île : Chargement..."
    IslandLabel.TextColor3 = Color3.fromRGB(0, 255, 180)
    IslandLabel.TextScaled = true
    IslandLabel.Parent = Frame

    spawn(function()
        while Frame.Parent do
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                IslandLabel.Text = "Île : " .. GetIsland(root.Position)
            end
            wait(3)
        end
    end)

    -- Tracer Button
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0.95, 0, 0, 32)
    Btn.Position = UDim2.new(0.025, 0, 0, 100)
    Btn.BackgroundColor3 = Color3.fromRGB(0, 160, 255)
    Btn.Text = "Tracer vers " .. player.Name
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.TextScaled = true
    Btn.Parent = Frame
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)

    Btn.MouseButton1Click:Connect(function()
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local targetRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if myRoot and targetRoot then
            local line = CreateRainbowLine()
            spawn(function()
                for i = 1, 90 do
                    if not targetRoot.Parent then break end
                    local p1 = Camera:WorldToViewportPoint(myRoot.Position)
                    local p2 = Camera:WorldToViewportPoint(targetRoot.Position)
                    line.From = Vector2.new(p1.X, p1.Y)
                    line.To = Vector2.new(p2.X, p2.Y)
                    line.Color = Color3.fromHSV((tick() * 8) % 1, 1, 1) -- Rainbow rapide
                    line.Visible = true
                    wait(0.016)
                end
                line:Remove()
            end)
        end
    end)
end

local function Refresh()
    for _, child in pairs(Scrolling:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            CreateEntry(plr)
        end
    end
end

local RefreshBtn = Instance.new("TextButton")
RefreshBtn.Size = UDim2.new(0.9, 0, 0, 35)
RefreshBtn.Position = UDim2.new(0.05, 0, 1, -45)
RefreshBtn.BackgroundColor3 = Color3.fromRGB(0, 220, 100)
RefreshBtn.Text = "Rafraîchir Liste"
RefreshBtn.TextColor3 = Color3.new(1,1,1)
RefreshBtn.TextScaled = true
RefreshBtn.Parent = MainFrame
Instance.new("UICorner", RefreshBtn).CornerRadius = UDim.new(0, 8)

RefreshBtn.MouseButton1Click:Connect(Refresh)

Refresh()

print("Blox Tracker by Exot chargé")
